<!DOCTYPE html>
<html lang="en">

<head>
  <title>Blog</title>
  <%- include('../partials/head.ejs') %>
    <style>
      .view-blog {
        position: relative;
        top: 5vh;
      }
    </style>
</head>

<body>

  <%- include('../partials/navbar.ejs') %>
    <% if (locals.blog) { %>
      <div class="view-blog">


        <div class="container mt-4 ">
          <h1>
            <%=blog.title %>
          </h1>
          <img src="<%=blog.coverImageUrl%>" alt="error" height="400">

          <pre> <p> <%=blog.body%></p> </pre>


          <div class="container mt-4">
            <img src="<%= blog.createdBy.profileImage %>" alt="profile" height="40">
            <%= blog.createdBy.fullName%>
          </div>

          <!-- comments -->

          <div class="container mt-4 p-4 bg-light rounded-4 shadow-sm">

            <h2 class="mb-3">Comments (<%= comments.length %>)</h2>
            <% if (locals.user) { %>
              <% if (typeof error !=="undefined" ) { %>
                <div class="alert alert-danger">
                  <%= error %>
                </div>
                <% } %>
                  <form method="post" action="/blog/comment/<%= blog._id %>">
                    <div class="mb-3">
                      <input type="text" name="content" class="form-control form-control-lg"
                        placeholder="Write a comment...">
                    </div>

                    <button type="submit" class="btn btn-primary px-4">
                      Add
                    </button>
                  </form>
                  <% } %>
          </div>

          <% if (comments) { %>
            <div class="container mt-4">

              <% comments.forEach(comment=> { %>
                <img src="<%= comment.createdBy.profileImage %>" height="40" alt="profile">
                <%=comment.createdBy.fullName %>

                  <pre><%= comment.content %></pre>
                  <% }) %>
            </div>
            <% } %>
        </div>
        <% } %>
      </div>
      <%- include('../partials/scripts.ejs') %>

</body>

</html>