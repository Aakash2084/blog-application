<!doctype html>
<html lang="en">

<head>
  <title>Blogify</title>
  <%- include('../partials/head.ejs') %>
</head>

<body>

  <!-- NAVBAR -->
  <%- include('../partials/navbar.ejs') %>

    <!-- HERO SECTION -->
    <div class="container py-5 text-center blog-start">
      <h1 class="fw-bold display-5">Welcome to Blogify</h1>
      <p class="text-muted">Read, write and share amazing stories.</p>
    </div>

    <!-- BLOGS -->
    <% if (locals.blogs) { %>

      <div class="container my-5">
        <div class="row g-4">

          <% blogs.forEach(blog=> { %>

            <div class="col-12 col-sm-6 col-md-4 col-lg-3">

              <div class="card h-100 shadow-sm rounded-4 border-0">

                <!-- BLOG IMAGE -->
                <img src="<%= blog.coverImageUrl %>" class="card-img-top rounded-top-4"
                  style="height: 180px; object-fit: cover;" alt="<%= blog.title %>">

                <!-- CARD BODY -->
                <div class="card-body d-flex flex-column">

                  <!-- BLOG TITLE -->
                  <h6 class="card-title fw-semibold text-dark mb-3" style="min-height: 48px; line-height: 1.2;">
                    <%= blog.title %>
                  </h6>

                  <!-- BUTTONS -->
                  <div class="d-flex gap-2 mt-auto">

                    <!-- VIEW BUTTON -->
                    <a href="/view-blog/<%= blog._id %>" class="btn btn-primary btn-sm px-3 py-1"
                      style="font-size:12px;">
                      View
                    </a>

                    <!-- DELETE BUTTON -->
                    <% if (user && blog.createdBy.toString()===user._id.toString()) { %>

                      <form action="/delete/<%= blog._id %>" method="POST" class="m-0">
                        <button class="btn btn-danger btn-sm px-3 py-1" style="font-size:12px;">
                          Delete
                        </button>
                      </form>

                      <% } %>

                  </div>

                </div>
              </div>

            </div>

            <% }) %>

        </div>
      </div>

      <% } %>

        <%- include('../partials/scripts.ejs') %>

</body>

</html>